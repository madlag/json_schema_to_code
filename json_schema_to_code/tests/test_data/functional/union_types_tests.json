              "anyOf": [
                {"$ref": "#/definitions/SimpleObject"},
                {"type": "null"}
              ]
            }
          }
        },
        "SimpleObject": {
          "type": "object",
          "properties": {
            "value": {"type": "string"}
          }
        }
      }
    },
    "expected_contains": [
      "FloatOrStr = float | str",
      "mixedField: FloatOrStr"
    ],
    "expected_not_contains": [
    ]
  },
