  {
    "name": "no_unions_no_aliases",
    "description": "Test schema with no unions generates no type aliases",
    "config": {
      "use_inline_unions": false
    },
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "SimpleClass": {
          "type": "object",
          "properties": {
            "stringField": {"type": "string"},
            "numberField": {"type": "number"},
            "boolField": {"type": "boolean"}
          }
        }
      }
    },
    "expected_contains": [
      "stringField: str",
      "numberField: float",
      "boolField: bool"
    ],
    "expected_not_contains": [
      "OrStr =",
      "OrFloat =",
      "OrBool ="
    ]
  },
  {
    "name": "oneOf_multiple_refs_type_alias",
    "description": "Test that oneOf with multiple $ref creates type alias instead of class",
    "config": {
      "use_inline_unions": false
    },
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "Component": {
          "type": "object",
          "properties": {
            "id": {"type": "string"}
          }
        },
        "Style": {
          "type": "object",
          "properties": {
            "color": {"type": "string"}
          }
        },
        "UIElement": {
          "oneOf": [
            {"$ref": "#/definitions/Component"},
            {"$ref": "#/definitions/Style"}
          ]
        },
        "TestClass": {
          "type": "object",
          "properties": {
            "element": {"$ref": "#/definitions/UIElement"}
          }
        }
      }
    },
    "expected_contains": [
      "UIElement = Component | Style",
      "class Component:",
      "class Style:",
      "class TestClass:",
      "element: UIElement"
    ],
    "expected_not_contains": [
      "class UIElement(",
      "class UIElement:",
      "class UIElement(Component",
      "class UIElement(Style"
    ]
  },
  {
    "name": "csharp_class_union_generates_valid_alias",
    "description": "C# union of two classes generates a valid PascalCase alias (e.g. ComponentOrStyle)",
    "test_language": "cs",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "Component": {
          "type": "object",
          "properties": { "id": {"type": "string"} }
        },
        "Style": {
          "type": "object",
          "properties": { "color": {"type": "string"} }
        },
        "Container": {
          "type": "object",
          "properties": {
            "child": {
              "anyOf": [
                {"$ref": "#/definitions/Component"},
                {"$ref": "#/definitions/Style"}
              ]
            }
          }
        }
      }
    },
    "expected_contains": [
      "ComponentOrStyle"
    ]
  },
  {
    "name": "csharp_class_and_array_union_raises_error",
    "description": "C# union of a class and an array (e.g. PitchNote | List<PitchedNote>) raises an error because the generated alias name is not a valid C# identifier",
    "test_language": "cs",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "PitchedNote": {
          "type": "object",
          "properties": { "note": {"type": "string"} }
        },
        "PitchNote": {
          "type": "object",
          "properties": { "note": {"type": "string"} }
        },
        "ScoreNote": {
          "type": "object",
          "properties": {
            "pitch": {
              "anyOf": [
                {"$ref": "#/definitions/PitchNote"},
                {
                  "type": "array",
                  "items": {"$ref": "#/definitions/PitchedNote"}
                }
              ]
            }
          }
        }
      }
    },
    "expected_error": "not a valid C# identifier"
  },
  {
    "name": "csharp_primitive_union_generates_valid_alias",
    "description": "C# union of primitives generates a valid alias (e.g. FloatOrString)",
    "test_language": "cs",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "TestClass": {
          "type": "object",
          "properties": {
            "value": {
              "anyOf": [
                {"type": "string"},
                {"type": "number"}
              ]
            }
          }
        }
      }
    },
    "expected_contains": [
      "FloatOrString"
    ]
  },
  {
    "name": "csharp_enum_and_array_union_raises_error",
    "description": "C# union of an enum and an array raises an error because List<T> in a union name is invalid",
    "test_language": "cs",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "definitions": {
        "Clef": {
          "type": "string",
          "enum": ["treble", "bass"]
        },
        "Score": {
          "type": "object",
          "properties": {
            "clef": {
              "anyOf": [
                {"$ref": "#/definitions/Clef"},
                {
                  "type": "array",
                  "items": {"$ref": "#/definitions/Clef"}
                }
              ]
            }
          }
        }
      }
    },
    "expected_error": "not a valid C# identifier"
  }
]
